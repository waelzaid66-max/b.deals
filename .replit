modules = ["nodejs-20", "nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck-mobile"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-icons"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck-admin"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck-dealer"

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck-mobile"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/banco-mobile run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-icons"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/banco-mobile run test:icons"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck-admin"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/admin-os run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck-dealer"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/dealer-os run typecheck"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 600000

[[ports]]
localPort = 3000
externalPort = 6800

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 8083
externalPort = 5173

[[ports]]
localPort = 8084
externalPort = 6000

[[ports]]
localPort = 21539
externalPort = 3001

[[ports]]
localPort = 22357
externalPort = 5000

[[ports]]
localPort = 23351
externalPort = 3000

[[ports]]
localPort = 23352
externalPort = 3002

[[ports]]
localPort = 23353
externalPort = 4200

[nix]
channel = "stable-25_05"
packages = ["psmisc"]

[objectStorage]
defaultBucketID = "replit-objstore-41fc812e-9f5e-42cb-93cc-f15445fe1efa"

[userenv]

[userenv.shared]
ADMIN_EMAILS = "info@bancoeg.com,wael_zeed@yahoo.com,waelzaid66@gmail.com"
PAYMOB_MODE = "sandbox"
