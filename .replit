modules = ["nodejs-20", "nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0", "javascript_object_storage:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 600000

[[ports]]
localPort = 3000
externalPort = 6800

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 8083
externalPort = 5173

[[ports]]
localPort = 8084
externalPort = 6000

[[ports]]
localPort = 21539
externalPort = 3001

[[ports]]
localPort = 22357
externalPort = 5000

[[ports]]
localPort = 23351
externalPort = 3000

[[ports]]
localPort = 23352
externalPort = 3002

[[ports]]
localPort = 23353
externalPort = 4200

[nix]
channel = "stable-25_05"
packages = ["psmisc"]

[objectStorage]
defaultBucketID = "replit-objstore-41fc812e-9f5e-42cb-93cc-f15445fe1efa"

[userenv]

